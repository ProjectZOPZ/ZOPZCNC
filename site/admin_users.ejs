<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOPZ STRESS | User Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        * { font-family: 'Inter', sans-serif; }
        body { 
            background: #0a0a0a;
            background-attachment: fixed;
        }
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #141414;
            --bg-card: #141414;
            --border-color: #1f1f1f;
            --border-hover: #1f1f1f;
            --accent-primary: #ffffff;
            --accent-secondary: #9ca3af;
        }
        .nav-active { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
        }
        .panel { 
            background: #141414;
            border: 1px solid #1f1f1f;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        .table-row:hover {
            background: #141414;
            border-left-color: #1f1f1f;
            transform: translateX(4px);
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen">
    <header class="border-b border-[#1f1f1f] bg-[#141414] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 flex items-center justify-center bg-[#0f0f0f] rounded border border-[#1f1f1f]">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h1 class="text-xl font-semibold text-white">ZOPZ STRESS</h1>
                </div>
                <nav class="flex flex-wrap items-center gap-1 w-full sm:w-auto justify-center sm:justify-end">
                    <a href="/dashboard/user" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] border border-[#1f1f1f] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span class="hidden sm:inline">Back to Dashboard</span>
                    </a>
                    <a href="/admin/dashboard" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        <span class="hidden sm:inline">Dashboard</span>
                    </a>
                    <a href="/admin/users" class="nav-active px-3 sm:px-4 py-2 rounded text-white transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                        <span class="hidden sm:inline">Users</span>
                    </a>
                    <a href="/admin/attacks" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="hidden sm:inline">Attacks</span>
                    </a>
                    <a href="/admin/logs" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">Logs</span>
                    </a>
                    <a href="/api-docs" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">API Docs</span>
                    </a>
                </nav>
                <a href="/login" class="px-3 py-2 text-red-400 hover:text-red-300 text-sm font-medium">Logout</a>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
            <div>
                <h1 class="text-4xl sm:text-5xl font-semibold mb-3 text-white">User Management</h1>
                <p class="text-[#9ca3af] text-sm sm:text-base">Manage all system users and permissions</p>
            </div>
            <div class="bg-[#141414] border border-[#1f1f1f] rounded px-6 py-4">
                <div class="text-xs text-[#9ca3af] font-medium mb-1 uppercase tracking-wider">Total Users</div>
                <div class="text-3xl font-semibold text-white"><%= users.length %></div>
            </div>
        </div>

        <% if (message) { %>
            <div class="mb-6 bg-[#141414] border border-green-500/30 rounded p-4 text-green-400 text-sm flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <%= message %>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="mb-6 bg-[#141414] border border-red-500/30 rounded p-4 text-red-400 text-sm flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <%= error %>
            </div>
        <% } %>

        <div class="panel rounded-lg p-4 sm:p-8">
            <% if (users && users.length > 0) { %>
                <div class="overflow-x-auto -mx-4 sm:mx-0">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-[#1f1f1f]">
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">User</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Status</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Expiry</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Limits</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Permissions</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#1f1f1f]">
                            <% users.forEach(u => { %>
                                <tr class="table-row">
                                    <td class="py-4 px-4 sm:px-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-12 h-12 bg-[#0f0f0f] rounded flex items-center justify-center border border-[#1f1f1f]">
                                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                            </div>
                                            <div>
                                                <div class="text-white font-semibold text-base"><%= u.username || 'N/A' %></div>
                                                <div class="flex items-center gap-2 mt-1">
                                                    <% if (u.admin) { %>
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-[#0f0f0f] text-white border border-[#1f1f1f]">Admin</span>
                                                    <% } %>
                                                    <% if (u.reseller) { %>
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-[#0f0f0f] text-white border border-[#1f1f1f]">Reseller</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <% if (u.banned) { %>
                                            <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-bold bg-gradient-to-r from-red-500/20 to-rose-500/20 text-red-300 border border-red-500/40">
                                                Banned
                                            </span>
                                        <% } else if (u.isExpired) { %>
                                            <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-bold bg-gradient-to-r from-yellow-500/20 to-amber-500/20 text-yellow-300 border border-yellow-500/40">
                                                Expired
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-bold bg-gradient-to-r from-emerald-500/20 to-teal-500/20 text-emerald-300 border border-emerald-500/40">
                                                Active
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6 text-white text-sm font-medium"><%= u.expiry || 'N/A' %></td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <div class="text-sm text-white font-medium">
                                            <div>Max: <span class="text-white font-semibold"><%= u.maxTime || 'N/A' %>s</span></div>
                                            <div class="text-[#9ca3af]">Concurrent: <span class="text-white font-semibold"><%= u.concurrents || 'N/A' %></span></div>
                                        </div>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <div class="flex flex-wrap gap-1.5">
                                            <% if (u.vip) { %>
                                                <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-[#0f0f0f] text-white border border-[#1f1f1f]">VIP</span>
                                            <% } %>
                                            <% if (u.api) { %>
                                                <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-[#0f0f0f] text-white border border-[#1f1f1f]">API</span>
                                            <% } %>
                                            <% if (!u.vip && !u.api) { %>
                                                <span class="text-[#9ca3af] text-xs">-</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <a href="/admin/users/<%= u.username %>/edit" 
                                               class="px-3 py-1.5 bg-[#0a0a0a] hover:bg-[#141414] border border-[#1f1f1f] rounded text-white text-xs font-medium transition-all">
                                                Edit
                                            </a>
                                            <button onclick="banUser('<%= u.username %>', <%= u.banned ? 'false' : 'true' %>)" 
                                                    class="px-3 py-1.5 <%= u.banned ? 'bg-[#0a0a0a] hover:bg-[#141414] border-[#1f1f1f] text-green-400' : 'bg-[#0a0a0a] hover:bg-[#141414] border-[#1f1f1f] text-red-400' %> border rounded text-xs font-medium transition-all">
                                                <%= u.banned ? 'Unban' : 'Ban' %>
                                            </button>
                                            <% if (u.username !== user.username) { %>
                                            <button onclick="deleteUser('<%= u.username %>')" 
                                                    class="px-3 py-1.5 bg-[#0a0a0a] hover:bg-[#141414] border border-[#1f1f1f] text-red-400 rounded text-xs font-medium transition-all">
                                                Delete
                                            </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-16 sm:py-20">
                    <div class="w-24 h-24 bg-[#0f0f0f] rounded flex items-center justify-center mx-auto mb-6 border border-[#1f1f1f]">
                        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                    </div>
                    <p class="text-white text-xl font-semibold mb-2">No users found</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        async function banUser(username, ban) {
            if (!confirm(ban ? `Are you sure you want to ban ${username}?` : `Are you sure you want to unban ${username}?`)) {
                return;
            }
            
            const reason = ban ? prompt('Enter ban reason (optional):') || 'No reason provided' : '';
            
            try {
                const response = await fetch(`/admin/users/${username}/ban`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `reason=${encodeURIComponent(reason)}`
                });
                
                const data = await response.json();
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function deleteUser(username) {
            if (!confirm(`Are you sure you want to DELETE ${username}? This action cannot be undone!`)) {
                return;
            }
            
            if (!confirm('This is your last chance. Delete user ' + username + '?')) {
                return;
            }
            
            try {
                const response = await fetch(`/admin/users/${username}/delete`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }
    </script>
</body>
</html>
