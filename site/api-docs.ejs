    <script>
        function toggleAccountDropdown() {
            const menu = document.getElementById('account-dropdown-menu');
            menu.classList.toggle('hidden');
        }

        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('account-dropdown');
            const menu = document.getElementById('account-dropdown-menu');
            if (!dropdown.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });

        // Fetch attack methods dynamically from API
        async function loadAttackMethods() {
            const methodsList = document.getElementById('methods-list');
            const methodsLoading = document.getElementById('methods-loading');
            
            try {
                const response = await fetch('/api/methods');
                const data = await response.json();
                
                if (data.success && data.methods && Array.isArray(data.methods)) {
                    methodsLoading.classList.add('hidden');
                    methodsList.classList.remove('hidden');
                    
                    // Clear existing items
                    methodsList.innerHTML = '';
                    
                    // Populate methods
                    data.methods.forEach(method => {
                        const li = document.createElement('li');
                        const methodName = method.name.toUpperCase();
                        const vipBadge = method.vip ? '<span class="ml-2 px-2 py-0.5 bg-[#141414] border border-[#1f1f1f] text-white text-xs rounded">VIP</span>' : '';
                        li.innerHTML = `<code>${methodName}</code>${vipBadge}`;
                        methodsList.appendChild(li);
                    });
                } else {
                    throw new Error('Invalid response format');
                }
            } catch (error) {
                console.error('Error loading methods:', error);
                methodsLoading.textContent = 'Failed to load methods. Please refresh the page.';
                methodsLoading.classList.add('text-red-400');
            }
        }
        
        // Load methods when page loads
        document.addEventListener('DOMContentLoaded', loadAttackMethods);
    </script>
