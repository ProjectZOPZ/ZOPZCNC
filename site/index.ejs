    <script>
        function showTab(tabId) {
            document.querySelectorAll('.content').forEach(content => {
                content.classList.remove('active');
            });
            
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
            });
            
            document.getElementById(tabId).classList.add('active');
            const activeLink = Array.from(document.querySelectorAll('.nav-link')).find(link => 
                link.getAttribute('onclick')?.includes(tabId)
            );
            if (activeLink) {
                activeLink.classList.add('active');
            }
            
            if (tabId === 'pricing') {
                showPricing('zopz');
            }

            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        function showPricing(pricingId) {
            document.querySelectorAll('.pricing-content').forEach(content => {
                content.classList.remove('active');
            });
            
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            document.getElementById(pricingId).classList.add('active');
            document.querySelector(`[data-pricing="${pricingId}"]`).classList.add('active');
        }
    </script>
