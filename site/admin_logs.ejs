<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOPZ STRESS | Attack Logs</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        * { font-family: 'Inter', sans-serif; }
        body { 
            background: #0a0a0a;
            background-attachment: fixed;
        }
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #141414;
            --bg-card: #141414;
            --border-color: #1f1f1f;
            --border-hover: #1f1f1f;
            --accent-primary: #ffffff;
            --accent-secondary: #9ca3af;
        }
        .nav-active { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
        }
        .glass { backdrop-filter: blur(10px) saturate(180%); }
        .panel { 
            background: #141414;
            border: 1px solid #1f1f1f;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        .table-row {
            transition: all 0.3s;
            border-left: 2px solid transparent;
        }
        .table-row:hover {
            background: #141414;
            border-left-color: #1f1f1f;
            transform: translateX(4px);
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen">
    <header class="border-b border-[#1f1f1f] bg-[#141414] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 flex items-center justify-center bg-[#0f0f0f] rounded border border-[#1f1f1f]">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h1 class="text-xl font-semibold text-white">ZOPZ STRESS</h1>
                </div>
                <nav class="flex flex-wrap items-center gap-1 w-full sm:w-auto justify-center sm:justify-end">
                    <a href="/dashboard/user" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] border border-[#1f1f1f] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span class="hidden sm:inline">Back to Dashboard</span>
                    </a>
                    <a href="/admin/dashboard" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        <span class="hidden sm:inline">Dashboard</span>
                    </a>
                    <a href="/admin/users" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                        <span class="hidden sm:inline">Users</span>
                    </a>
                    <a href="/admin/attacks" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="hidden sm:inline">Attacks</span>
                    </a>
                    <a href="/admin/logs" class="nav-active px-3 sm:px-4 py-2 rounded text-white transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">Logs</span>
                    </a>
                    <a href="/api-docs" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">API Docs</span>
                    </a>
                </nav>
                <a href="/login" class="px-3 py-2 text-red-400 hover:text-red-300 text-sm font-medium">Logout</a>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
            <div>
                <h1 class="text-4xl sm:text-5xl font-semibold mb-3 text-white">Attack Logs</h1>
                <p class="text-[#9ca3af] text-sm sm:text-base">Complete history of all attack operations</p>
            </div>
            <div class="bg-[#141414] border border-[#1f1f1f] rounded px-6 py-4">
                <div class="text-xs text-[#9ca3af] font-medium mb-1 uppercase tracking-wider">Total Entries</div>
                <div class="text-3xl font-semibold text-white"><%= attackLogs.length %></div>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 bg-[#141414] border border-red-500/30 rounded p-4 flex items-center gap-3">
                <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-red-400"><%= error %></span>
            </div>
        <% } %>

        <div class="panel rounded-lg p-4 sm:p-8">
            <% if (attackLogs && attackLogs.length > 0) { %>
                <div class="overflow-x-auto -mx-4 sm:mx-0">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-[#1f1f1f]">
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">User</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Target</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Port</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Method</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Duration</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Date/Time</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Concurrent</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#1f1f1f]">
                            <% attackLogs.forEach(log => { %>
                                <tr class="table-row">
                                    <td class="py-4 px-4 sm:px-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-12 h-12 bg-[#0f0f0f] rounded flex items-center justify-center border border-[#1f1f1f]">
                                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                            </div>
                                            <span class="text-white font-semibold"><%= log.user || 'N/A' %></span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <span class="text-white font-medium text-sm"><%= log.target || 'N/A' %></span>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6 text-white font-semibold"><%= log.port || 'N/A' %></td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <span class="inline-flex items-center px-3 py-1.5 rounded text-xs font-medium bg-[#0f0f0f] text-white border border-[#1f1f1f]">
                                            <%= log.method || 'N/A' %>
                                        </span>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6 text-white font-semibold"><%= log.time || 'N/A' %>s</td>
                                    <td class="py-4 px-4 sm:px-6 text-[#9ca3af] text-sm"><%= log.datetime || 'N/A' %></td>
                                    <td class="py-4 px-4 sm:px-6 text-white font-medium">
                                        <% if (log.concurrent || log.totalConcurrents) { %>
                                            <%= log.concurrent ? log.concurrent + '/' + (log.totalConcurrents || 1) : 'N/A' %>
                                        <% } else { %>
                                            <span class="text-[#9ca3af]">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-16 sm:py-20">
                    <div class="w-24 h-24 bg-[#0f0f0f] rounded flex items-center justify-center mx-auto mb-6 border border-[#1f1f1f]">
                        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                    </div>
                    <p class="text-white text-xl font-semibold mb-2">No attack logs found</p>
                    <p class="text-[#9ca3af] text-sm">Logs will appear here as attacks are sent</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>
