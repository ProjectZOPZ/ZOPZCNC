<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOPZ STRESS | Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        * { font-family: 'Inter', sans-serif; }
        body { 
            background: #0a0a0a;
            background-attachment: fixed;
        }
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #141414;
            --bg-card: #141414;
            --border-color: #1f1f1f;
            --border-hover: #1f1f1f;
            --accent-primary: #ffffff;
            --accent-secondary: #9ca3af;
        }
        .nav-active { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
        }
        .btn-primary { 
            background: white; 
            color: #0a0a0a;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }
        .btn-primary:hover { 
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
            background: #f0f0f0;
        }
        .input-field { 
            background: #0a0a0a; 
            border: 1px solid #1f1f1f; 
            backdrop-filter: blur(10px);
        }
        .input-field:focus { 
            border-color: #1f1f1f; 
            outline: none;
            ring: 2px;
            ring-color: rgba(255, 255, 255, 0.1);
        }
        .panel { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
            backdrop-filter: blur(10px);
            transition: all 0.3s;
        }
        .panel:hover {
            border-color: #1f1f1f;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        .metric-card { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen">
    <!-- Top Header -->
    <header class="border-b border-[#1f1f1f] bg-[#141414] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 flex items-center justify-center bg-[#0f0f0f] rounded border border-[#1f1f1f]">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h1 class="text-xl font-semibold text-white">ZOPZ STRESS</h1>
                </div>

                <!-- Top Navigation -->
                <nav class="flex items-center gap-1">
                    <a href="/dashboard/user" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        <span class="text-sm font-medium">Dashboard</span>
                    </a>
                    <a href="/dashboard/attack" class="nav-active px-4 py-2 rounded text-white transition-all flex items-center gap-2">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="text-sm font-medium">Panel</span>
                    </a>
                    <a href="/dashboard/methods" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span class="text-sm font-medium">Methods</span>
                    </a>
                    <a href="/dashboard/logs" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <span class="text-sm font-medium">AttackLogs</span>
                    </a>
                    <a href="/api-docs" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="text-sm font-medium">API Docs</span>
                    </a>
                    <% if (typeof user !== 'undefined' && user && user.admin) { %>
                    <a href="/admin/dashboard" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] border border-[#1f1f1f] transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        <span class="text-sm font-medium">Admin</span>
                    </a>
                    <% } %>
                </nav>

                <!-- Account Dropdown -->
                <div class="flex items-center gap-3">
                    <div class="relative" id="account-dropdown">
                        <button onclick="toggleAccountDropdown()" class="px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm font-medium">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <span>Account</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div id="account-dropdown-menu" class="hidden absolute right-0 mt-2 w-48 bg-[#141414] border border-[#1f1f1f] rounded shadow-xl z-50">
                            <a href="/dashboard/user" class="block px-4 py-3 text-sm text-[#9ca3af] hover:bg-[#0f0f0f] hover:text-white transition-all flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                <span>Plan</span>
                            </a>
                            <a href="/login" class="block px-4 py-3 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-all flex items-center gap-2 border-t border-[#1f1f1f]">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                </svg>
                                <span>Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Metrics Bar -->
    <div class="border-b border-[#1f1f1f] bg-[#141414]">
        <div class="max-w-7xl mx-auto px-6 py-3">
            <div class="flex items-center gap-6 flex-wrap">
                <div class="metric-card px-4 py-2 rounded flex items-center gap-2">
                    <svg class="w-4 h-4 text-[#9ca3af]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    <span class="text-xs text-[#9ca3af]">Plan:</span>
                    <span class="text-sm font-medium text-white"><%= user.plan || 'Normal' %></span>
                </div>
                <div class="metric-card px-4 py-2 rounded flex items-center gap-2">
                    <svg class="w-4 h-4 text-[#9ca3af]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    <span class="text-xs text-[#9ca3af]">Slots:</span>
                    <span class="text-sm font-medium text-white"><%= user.concurrents || 1 %></span>
                </div>
                <div class="metric-card px-4 py-2 rounded flex items-center gap-2">
                    <svg class="w-4 h-4 text-[#9ca3af]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="text-xs text-[#9ca3af]">Max Time:</span>
                    <span class="text-sm font-medium text-white"><%= user.maxTime || 300 %>s</span>
                </div>
                <div class="metric-card px-4 py-2 rounded flex items-center gap-2">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <span class="text-xs text-[#9ca3af]">Active:</span>
                    <span class="text-sm font-medium text-white">0/<%= user.concurrents || 1 %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Left Column: Attack Control -->
            <div class="panel rounded-lg p-6">
                <div class="flex items-center gap-2 mb-1">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <h2 class="text-lg font-semibold text-white">Attack Control</h2>
                </div>
                <p class="text-xs text-[#9ca3af] mb-6 uppercase tracking-wider">SET PARAMETERS BEFORE LAUNCH</p>

                <% if (message) { %>
                    <div class="mb-4 bg-[#141414] border border-green-500/30 rounded p-3 text-green-400 text-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <%= message %>
                    </div>
                <% } %>
                <% if (error) { %>
                    <div class="mb-4 bg-[#141414] border border-red-500/30 rounded p-3 text-red-400 text-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        <%= error %>
                    </div>
                <% } %>

                <form action="/attack" method="POST" class="space-y-4">
                    <!-- Target -->
                    <div>
                        <label class="block text-xs font-medium text-[#9ca3af] mb-2 uppercase tracking-wider">Target</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="w-4 h-4 text-[#9ca3af]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                            <input type="text" id="host" name="host" 
                                   class="input-field w-full pl-10 pr-4 py-3 rounded text-white text-sm focus:border-[#1f1f1f] transition-colors" 
                                   placeholder="https://example.com/" required>
                        </div>
                    </div>

                    <!-- Method & Port -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-[#9ca3af] mb-2 uppercase tracking-wider">Method</label>
                            <select id="method" name="method" 
                                    class="input-field w-full px-4 py-3 rounded text-white text-sm focus:border-[#1f1f1f] transition-colors" required>
                                <% if (attackMethods && attackMethods.length > 0) { %>
                                    <% attackMethods.forEach(method => { %>
                                        <option value="<%= method.name %>"><%= method.name %> <% if(method.vip){ %>(VIP)<% } %></option>
                                    <% }) %>
                                <% } else { %>
                                    <option value="" disabled>No methods available</option>
                                <% } %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-[#9ca3af] mb-2 uppercase tracking-wider">Port</label>
                            <input type="number" id="port" name="port" 
                                   class="input-field w-full px-4 py-3 rounded text-white text-sm focus:border-[#1f1f1f] transition-colors" 
                                   placeholder="80" required>
                        </div>
                    </div>

                    <!-- Duration -->
                    <div>
                        <label class="block text-xs font-medium text-[#9ca3af] mb-2 uppercase tracking-wider">Duration</label>
                        <input type="number" id="time" name="time" 
                               class="input-field w-full px-4 py-3 rounded text-white text-sm focus:border-[#1f1f1f] transition-colors" 
                               placeholder="300" required>
                    </div>

                    <!-- Length (optional) -->
                    <div>
                        <label class="block text-xs font-medium text-[#9ca3af] mb-2 uppercase tracking-wider">Length <span class="text-[#9ca3af] normal-case">(optional)</span></label>
                        <input type="number" id="len" name="len" 
                               class="input-field w-full px-4 py-3 rounded text-white text-sm focus:border-[#1f1f1f] transition-colors" 
                               placeholder="1024">
                    </div>

                    <!-- Launch Button -->
                    <button type="submit" 
                            class="btn-primary w-full py-3 rounded text-[#0a0a0a] font-medium text-sm transition-all hover:bg-opacity-80">
                        Launch Attack
                    </button>
                </form>
            </div>

            <!-- Right Column: Active Attacks -->
            <div class="panel rounded-lg p-6">
                <div class="flex items-center gap-2 mb-1">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <h2 class="text-lg font-semibold text-white">Active Attacks</h2>
                </div>
                <p class="text-xs text-[#9ca3af] mb-6 uppercase tracking-wider">LIVE OPERATIONS OVERVIEW</p>

                <div id="active-attacks-container">
                    <% if (typeof activeAttacks !== 'undefined' && activeAttacks && activeAttacks.length > 0) { %>
                        <div class="space-y-3">
                            <% activeAttacks.forEach(attack => { %>
                                <div class="bg-[#0a0a0a] border border-[#1f1f1f] rounded p-4">
                                    <div class="flex items-center justify-between mb-2">
                                        <div class="flex items-center gap-2">
                                            <span class="text-white font-medium text-sm"><%= attack.method %></span>
                                        </div>
                                        <span class="text-xs text-[#9ca3af]"><%= Math.floor(attack.remainingTime / 60) %>m <%= attack.remainingTime % 60 %>s</span>
                                    </div>
                                    <div class="text-xs text-[#9ca3af] font-mono"><%= attack.host %>:<%= attack.port %></div>
                                    <div class="text-xs text-[#9ca3af] mt-1">Duration: <%= attack.time %>s</div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="flex flex-col items-center justify-center py-12">
                            <div class="w-16 h-16 bg-[#0f0f0f] rounded flex items-center justify-center mb-4 border border-[#1f1f1f]">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                </svg>
                            </div>
                            <p class="text-[#9ca3af] text-sm font-medium">No active attacks</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Function to update active attacks without page refresh
        async function updateActiveAttacks() {
            try {
                const response = await fetch('/api/active-attacks');
                const data = await response.json();
                
                const container = document.getElementById('active-attacks-container');
                
                if (data.success && data.activeAttacks && data.activeAttacks.length > 0) {
                    let html = '<div class="space-y-3">';
                    data.activeAttacks.forEach(attack => {
                        const minutes = Math.floor(attack.remainingTime / 60);
                        const seconds = attack.remainingTime % 60;
                        html += `
                            <div class="bg-[#0a0a0a] border border-[#1f1f1f] rounded p-4">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <span class="text-white font-medium text-sm">${attack.method}</span>
                                    </div>
                                    <span class="text-xs text-[#9ca3af]">${minutes}m ${seconds}s</span>
                                </div>
                                <div class="text-xs text-[#9ca3af] font-mono">${attack.host}:${attack.port}</div>
                                <div class="text-xs text-[#9ca3af] mt-1">Duration: ${attack.time}s</div>
                            </div>
                        `;
                    });
                    html += '</div>';
                    container.innerHTML = html;
                } else {
                    container.innerHTML = `
                        <div class="flex flex-col items-center justify-center py-12">
                            <div class="w-16 h-16 bg-[#0f0f0f] rounded flex items-center justify-center mb-4 border border-[#1f1f1f]">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                </svg>
                            </div>
                            <p class="text-[#9ca3af] text-sm font-medium">No active attacks</p>
                        </div>
                    `;
                }
            } catch (err) {
                console.error('Error updating active attacks:', err);
            }
        }

        // Update every 2 seconds
        setInterval(updateActiveAttacks, 2000);
        
        // Initial update after page load
        setTimeout(updateActiveAttacks, 500);

        function toggleAccountDropdown() {
            const menu = document.getElementById('account-dropdown-menu');
            menu.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('account-dropdown');
            const menu = document.getElementById('account-dropdown-menu');
            if (!dropdown.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });
    </script>

</body>
</html>
