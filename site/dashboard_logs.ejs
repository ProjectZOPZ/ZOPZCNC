<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AttackLogs | ZOPZ STRESS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        * { font-family: 'Inter', sans-serif; }
        body { 
            background: #0a0a0a;
            background-attachment: fixed;
        }
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #141414;
            --bg-card: #141414;
            --border-color: #1f1f1f;
            --border-hover: #1f1f1f;
            --accent-primary: #ffffff;
            --accent-secondary: #9ca3af;
        }
        .nav-active { 
            background: #141414; 
            border: 1px solid #1f1f1f; 
        }
        .panel { 
            background: #141414;
            border: 1px solid #1f1f1f;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        .table-row {
            transition: all 0.3s;
            border-left: 2px solid transparent;
        }
        .table-row:hover {
            background: #141414;
            border-left-color: #1f1f1f;
            transform: translateX(4px);
        }
        .badge {
            background: #0f0f0f;
            border: 1px solid #1f1f1f;
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen">
    <header class="border-b border-[#1f1f1f] bg-[#141414] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 flex items-center justify-center bg-[#0f0f0f] rounded border border-[#1f1f1f]">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h1 class="text-xl font-semibold text-white">ZOPZ STRESS</h1>
                </div>
                <nav class="flex flex-wrap items-center gap-1 w-full sm:w-auto justify-center sm:justify-end">
                    <a href="/dashboard/user" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        <span class="hidden sm:inline">Dashboard</span>
                    </a>
                    <a href="/dashboard/attack" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span class="hidden sm:inline">Panel</span>
                    </a>
                    <a href="/dashboard/methods" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span class="hidden sm:inline">Methods</span>
                    </a>
                    <a href="/dashboard/logs" class="nav-active px-3 sm:px-4 py-2 rounded text-white transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">AttackLogs</span>
                    </a>
                    <a href="/api-docs" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span class="hidden sm:inline">API Docs</span>
                    </a>
                    <% if (typeof user !== 'undefined' && user && user.admin) { %>
                    <a href="/admin/dashboard" class="px-3 sm:px-4 py-2 rounded text-[#9ca3af] hover:text-white hover:bg-[#141414] border border-[#1f1f1f] transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        <span class="hidden sm:inline">Admin</span>
                    </a>
                    <% } %>
                </nav>
                <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                    <div class="relative" id="account-dropdown">
                        <button onclick="toggleAccountDropdown()" class="px-3 sm:px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800/50 transition-all flex items-center gap-2 text-sm font-medium">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <span class="hidden sm:inline">Account</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div id="account-dropdown-menu" class="hidden absolute right-0 mt-2 w-48 bg-[#141414] border border-[#1f1f1f] rounded shadow-lg z-50">
                            <a href="/dashboard/user" class="block px-4 py-3 text-sm text-[#9ca3af] hover:bg-[#0f0f0f] hover:text-white transition-all flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                <span>Plan</span>
                            </a>
                            <a href="/login" class="block px-4 py-3 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-all flex items-center gap-2 border-t border-[#1f1f1f]">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                </svg>
                                <span>Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="border-b border-[#1f1f1f] bg-[#141414]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
            <div class="flex items-center gap-4 sm:gap-6 flex-wrap">
                <div class="bg-[#141414] border border-[#1f1f1f] rounded px-4 py-2 flex items-center gap-2">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    <span class="text-xs text-[#9ca3af]">Plan:</span>
                    <span class="text-sm font-medium text-white"><%= typeof user !== 'undefined' && user ? (user.plan || 'Normal') : 'Normal' %></span>
                </div>
            </div>
        </div>
    </div>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
        <div class="mb-8">
            <h1 class="text-4xl sm:text-5xl font-semibold mb-3 text-white">Attack Logs</h1>
            <p class="text-[#9ca3af] text-sm sm:text-base">View your complete attack history and analytics</p>
        </div>

        <% if (typeof message !== 'undefined' && message) { %>
            <div class="mb-6 bg-[#141414] border border-green-500/30 rounded p-4 text-green-400 text-sm flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <%= message %>
            </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 bg-[#141414] border border-red-500/30 rounded p-4 text-red-400 text-sm flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <%= error %>
            </div>
        <% } %>

        <div class="panel rounded-lg p-4 sm:p-8">
            <% if (attackLogs && attackLogs.length > 0) { %>
                <div class="overflow-x-auto -mx-4 sm:mx-0">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-[#1f1f1f]">
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Target</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Port</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Method</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Duration</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Time Sent</th>
                                <th class="text-left py-4 px-4 sm:px-6 text-xs font-medium text-[#9ca3af] uppercase tracking-wider">Concurrent</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#1f1f1f]">
                            <% attackLogs.forEach(log => { %>
                                <tr class="table-row">
                                    <td class="py-4 px-4 sm:px-6">
                                        <span class="text-white font-medium text-sm"><%= log.target || 'N/A' %></span>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6 text-white text-sm font-medium"><%= log.port || 'N/A' %></td>
                                    <td class="py-4 px-4 sm:px-6">
                                        <span class="badge inline-flex items-center px-3 py-1.5 rounded text-xs font-medium text-white">
                                            <%= log.method || 'N/A' %>
                                        </span>
                                    </td>
                                    <td class="py-4 px-4 sm:px-6 text-white text-sm font-medium"><%= log.time || 'N/A' %>s</td>
                                    <td class="py-4 px-4 sm:px-6 text-[#9ca3af] text-sm"><%= log.datetime || 'N/A' %></td>
                                    <td class="py-4 px-4 sm:px-6 text-white text-sm font-medium">
                                        <% if (log.concurrent || log.totalConcurrents) { %>
                                            <%= log.concurrent ? log.concurrent + '/' + (log.totalConcurrents || 1) : 'N/A' %>
                                        <% } else { %>
                                            <span class="text-[#9ca3af]">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-16 sm:py-20">
                    <div class="w-24 h-24 bg-[#0f0f0f] rounded flex items-center justify-center mx-auto mb-6 border border-[#1f1f1f]">
                        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                    </div>
                    <p class="text-white text-xl font-semibold mb-2">No attack logs found</p>
                    <p class="text-[#9ca3af] text-sm">Your attack history will appear here</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        function toggleAccountDropdown() {
            const menu = document.getElementById('account-dropdown-menu');
            menu.classList.toggle('hidden');
        }

        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('account-dropdown');
            const menu = document.getElementById('account-dropdown-menu');
            if (!dropdown.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
